{
  "name": "cside",
  "version": "0.0.46",
  "description": "ChoiceScript IDE — a dedicated editor for authoring ChoiceScript games",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "diag": "node ./node_modules/esbuild/bin/esbuild scripts/diagnose.ts --bundle --platform=node --format=cjs --outfile=scripts/diagnose.cjs --loader:.css=empty --jsx=automatic --log-level=error && node scripts/diagnose.cjs",
    "diag:app": "electron-vite build && node scripts/diagApp.cjs",
    "dist": "electron-vite build && electron-builder && node scripts/archiveRelease.cjs",
    "release": "node scripts/publishRelease.cjs",
    "check:game": "node ./node_modules/esbuild/bin/esbuild scripts/checkGame.ts --bundle --platform=node --format=cjs --outfile=scripts/checkGame.cjs --loader:.css=empty --log-level=error && node scripts/checkGame.cjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.11.2",
    "dagre": "^0.8.5",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "elkjs": "^0.11.1",
    "html-to-image": "^1.11.13",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.7.0",
    "vite": "^7.3.0"
  }
}
